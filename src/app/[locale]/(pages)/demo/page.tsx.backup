      <script dangerouslySetInnerHTML={{
        __html: `
          function initializeDemo() {
            // Remove any existing event listeners
            const startDemoBtn = document.getElementById('start-demo');
            const demoContainer = document.getElementById('demo-container');
            const uploadStep = document.getElementById('upload-step');
            const loadingStep = document.getElementById('loading-step');
            const resultsStep = document.getElementById('results-step');
            const convalidateBtn = document.getElementById('convalidate-btn');
            const restartDemoBtn = document.getElementById('restart-demo');
            const loadingText = document.getElementById('loading-text');
            const progressBar = document.getElementById('progress-bar');
            const heroSection = document.getElementById('hero-section');
            const featuresSection = document.getElementById('features-section');

            // Reset demo state
            if (demoContainer) demoContainer.classList.add('hidden');
            if (uploadStep) uploadStep.classList.remove('hidden');
            if (loadingStep) loadingStep.classList.add('hidden');
            if (resultsStep) resultsStep.classList.add('hidden');
            if (heroSection) heroSection.classList.remove('hidden');
            if (featuresSection) featuresSection.classList.remove('hidden');

            // Reset upload zones
            document.querySelectorAll('.upload-zone').forEach(zone => {
              zone.classList.remove('border-green-400', 'bg-green-50');
              const status = zone.querySelector('.upload-status');
              const input = zone.querySelector('input');
              if (status) status.classList.add('hidden');
              if (input) input.value = '';
            });

            // Upload zones
            document.querySelectorAll('.upload-zone').forEach(zone => {
              const input = zone.querySelector('input[type="file"]');
              const status = zone.querySelector('.upload-status');
              
              // Remove existing listeners
              zone.replaceWith(zone.cloneNode(true));
            });

            // Re-select elements after cloning
            document.querySelectorAll('.upload-zone').forEach(zone => {
              const input = zone.querySelector('input[type="file"]');
              const status = zone.querySelector('.upload-status');
              
              zone.addEventListener('click', () => {
                input.click();
              });

              zone.addEventListener('dragover', (e) => {
                e.preventDefault();
                zone.classList.add('border-blue-400', 'bg-blue-50');
              });

              zone.addEventListener('dragleave', () => {
                zone.classList.remove('border-blue-400', 'bg-blue-50');
              });

              zone.addEventListener('drop', (e) => {
                e.preventDefault();
                zone.classList.remove('border-blue-400', 'bg-blue-50');
                simulateFileUpload(zone, status);
              });

              input.addEventListener('change', () => {
                simulateFileUpload(zone, status);
              });
            });

            function simulateFileUpload(zone, status) {
              zone.classList.add('border-green-400', 'bg-green-50');
              status.classList.remove('hidden');
            }

            // Loading messages and progress
            const loadingMessages = [
              'Analizando documentos con IA...',
              'Extrayendo información académica...',
              'Comparando con base de datos de currículos...',
              'Calculando similitudes entre materias...',
              'Aplicando algoritmos de convalidación...',
              'Generando reporte final...'
            ];

            if (startDemoBtn) {
              startDemoBtn.addEventListener('click', function() {
                if (heroSection) heroSection.classList.add('hidden');
                if (featuresSection) featuresSection.classList.add('hidden');
                if (demoContainer) {
                  demoContainer.classList.remove('hidden');
                  uploadStep.scrollIntoView({ behavior: 'smooth' });
                }
              });
            }

            if (convalidateBtn) {
              convalidateBtn.addEventListener('click', function() {
                uploadStep.classList.add('hidden');
                loadingStep.classList.remove('hidden');
                
                let messageIndex = 0;
                let progress = 0;
                
                // Reset progress bar
                if (progressBar) {
                  progressBar.style.width = '0%';
                }
                
                const updateProgress = () => {
                  if (messageIndex < loadingMessages.length) {
                    if (loadingText) loadingText.textContent = loadingMessages[messageIndex];
                    progress = ((messageIndex + 1) / loadingMessages.length) * 100;
                    if (progressBar) progressBar.style.width = progress + '%';
                    messageIndex++;
                    
                    setTimeout(updateProgress, 2000);
                  } else {
                    setTimeout(() => {
                      loadingStep.classList.add('hidden');
                      resultsStep.classList.remove('hidden');
                      resultsStep.scrollIntoView({ behavior: 'smooth' });
                    }, 1000);
                  }
                };
                
                setTimeout(updateProgress, 1000);
              });
            }

            if (restartDemoBtn) {
              restartDemoBtn.addEventListener('click', function() {
                // Reset demo
                resultsStep.classList.add('hidden');
                loadingStep.classList.add('hidden');
                uploadStep.classList.remove('hidden');
                
                // Reset upload zones
                document.querySelectorAll('.upload-zone').forEach(zone => {
                  zone.classList.remove('border-green-400', 'bg-green-50');
                  const status = zone.querySelector('.upload-status');
                  const input = zone.querySelector('input');
                  if (status) status.classList.add('hidden');
                  if (input) input.value = '';
                });
                
                uploadStep.scrollIntoView({ behavior: 'smooth' });
              });
            }
          }

          // Initialize on page load
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initializeDemo);
          } else {
            initializeDemo();
          }

          // Re-initialize when navigating back to this page
          window.addEventListener('pageshow', initializeDemo);
        `
      }} />
    </main>
  );
}